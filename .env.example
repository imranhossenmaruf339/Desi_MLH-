BOT_TOKEN=
API_ID=
API_HASH=
MONGO_URI=

# Admin user IDs (comma-separated for multiple admins)
ADMIN_ID=

# ── Channels ──────────────────────────────────────────────────────────────────
# Channel where bot auto-indexes videos from (numeric ID e.g. -1001234567890)
VIDEO_CHANNEL_ID=

# Linked discussion/comments group of VIDEO_CHANNEL_ID
# Bot forwards video comments to LOG_CHANNEL_ID from here
DISCUSSION_GROUP_ID=

# ── Groups ────────────────────────────────────────────────────────────────────
# Monitor group — join requests, auto-index notices, ban/unban logs, comments
LOG_CHANNEL_ID=

# Control group — admin can run /stats /broadcast /ban etc. from here
CONTROL_GROUP_ID=

# Support/inbox group — user messages are forwarded here; admin replies go back
SUPPORT_GROUP_ID=

# Required group — users must join to get videos (force-join)
REQUIRED_GROUP_ID=
REQUIRED_GROUP_LINK=

# ── Limits ────────────────────────────────────────────────────────────────────
VIDEO_DAILY_LIMIT=10
GROUP_VIDEO_LIMIT=5
